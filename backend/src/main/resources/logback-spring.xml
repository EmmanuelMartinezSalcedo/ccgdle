<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appender name="FILE" class="ch.qos.logback.core.FileAppender">
    <file>logs/card-sync.log</file>
    <append>false</append>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="com.ccgdle.backend.service.CardService" level="INFO"/>
  <logger name="com.ccgdle.backend.service" level="INFO"/>

  <root level="INFO">
    <appender-ref ref="FILE"/>
  </root>
</configuration>